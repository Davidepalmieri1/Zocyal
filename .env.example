NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only Supabase secret. Never prefix this variable with NEXT_PUBLIC_.
SUPABASE_SECRET_KEY=your-sb-secret-or-service-role-key

# Password used by the organizer to enter /admin.
ADMIN_PASSWORD=replace-with-a-long-unique-password

# Generate a random value of at least 32 characters. Never expose this publicly.
ADMIN_SESSION_SECRET=replace-with-a-random-secret-at-least-32-characters
